a = 6  # Binary: 0110
b = 3  # Binary: 0011

print("Bitwise AND (a & b):", a & b)   # 0010 -> 2
print("Bitwise OR (a | b):", a | b)    # 0111 -> 7
print("Bitwise XOR (a ^ b):", a ^ b)   # 0101 -> 5
print("Bitwise NOT (~a):", ~a)         # -(a+1) -> -7
print("Left Shift (a << 1):", a << 1) # 1100 -> 12
print("Right Shift (a >> 1):", a >> 1) # 0011 -> 3
