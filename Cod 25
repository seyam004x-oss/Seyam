list1 = [1, 2, 3]
list2 = [1, 2, 3]
list3 = list1

# 'is' checks if they point to the exact same object in memory
print("list1 is list2:", list1 is list2)       # False (different memory addresses)
print("list1 is list3:", list1 is list3)       # True (same object)
print("list1 is not list2:", list1 is not list2) # True
